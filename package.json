    "allure:report": "npm --prefix playwright run allure:report",
    "lint": "eslint playwright/tests/ playwright/src/pages/ --ext .ts",
    "lint:ci": "eslint playwright/tests/ playwright/src/pages/ --ext .ts --max-warnings=0",
    "lint:fix": "eslint playwright/tests/ playwright/src/pages/ --ext .ts --fix"
  },
