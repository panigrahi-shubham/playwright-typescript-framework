{
  "name": "playwright",
  "version": "1.0.0",
  "description": "Playwright test project for cross-browser UI automation with TypeScript.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:ci": "playwright test",
    "smoke": "playwright test --grep @smoke",
    "regression": "playwright test --grep @regression",
    "auth": "playwright test --grep @auth",
    "no-slow": "playwright test --grep-invert @slow",
    "lint": "eslint tests/ src/pages/ --ext .ts",
    "lint:fix": "eslint tests/ src/pages/ --ext .ts --fix",
    "report": "playwright show-report",
    "allure:gen": "npx allure generate allure-results --clean",
    "allure:open": "npx allure open allure-report",
    "allure:report": "npm run allure:gen && npm run allure:open",
    "headed": "playwright test --headed",
    "debug": "playwright test --debug",
    "test:smoke": "npm run smoke",
    "test:headed": "npm run headed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1"
  }
}
