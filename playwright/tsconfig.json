{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "."
  },
  "include": [
    "playwright.config.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "utils/**/*.ts",
    "data/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "allure-report",
    "allure-results",
    "playwright-report",
    "test-results"
  ]
}
